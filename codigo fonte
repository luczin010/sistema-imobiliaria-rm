# ====================================

print("===== SISTEMA IMOBILIÁRIA R.M =====")

# tipo do imóvel
tipo = input(
    "Digite o tipo do imóvel (apartamento/casa/estudio): "
)

# quartos
quartos = 1

if tipo.lower() != "estudio":
    quartos = int(
        input("Quantidade de quartos (1 ou 2): ")
    )

# garagem/vagas
vagas = int(
    input("Quantidade de vagas/garagem: ")
)

# crianças
criancas = False

if tipo.lower() == "apartamento":

    resposta = input(
        "Possui crianças? (s/n): "
    )

    if resposta.lower() == "s":
        criancas = True

# criando objetos
imovel = Imovel(
    tipo,
    quartos,
    vagas,
    criancas
)

contrato = Contrato()

orcamento = Orcamento(
    imovel,
    contrato
)

# mostrando orçamento
valor_final = orcamento.mostrar_orcamento()

# gerando CSV
arquivo = ArquivoCSV()
arquivo.gerar_csv(valor_final)
